# OpenResty API Proxy Gateway - 环境变量配置
# 复制此文件为 .env 并填入实际的 API Key

# Zerion API Configuration
ZERION_API_KEY=your_zerion_api_key_here
ZERION_ENDPOINT=https://api.zerion.io

# CoinGecko API Configuration
COINGECKO_API_KEY=your_coingecko_api_key_here
COINGECKO_ENDPOINT=https://api.coingecko.com

# Alchemy API Configuration
ALCHEMY_API_KEY=your_alchemy_api_key_here
ALCHEMY_ENDPOINT=https://eth-mainnet.g.alchemy.com

# GeoIP Configuration (可选)
GEOIP_ENABLED=false
GEOIP_MODE=blacklist
GEOIP_COUNTRIES=CN,RU,KP
GEOIP_ALLOW_UNKNOWN=true
# GEOIP_DATABASE=/usr/local/openresty/geoip/GeoLite2-Country.mmdb

# Grafana Configuration
GRAFANA_PASSWORD=admin
