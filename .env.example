# OpenResty API Proxy Gateway - 环境变量配置
# 复制此文件为 .env 并填入实际的配置

# ============================================
# 认证方式说明
# ============================================
# 客户端统一通过 X-API-Key Header 传递 API_KEY
# 网关根据各 provider 的认证格式要求，自动转换并注入到上游请求
#
# 使用示例:
#   # Zerion API
#   curl -H "X-API-Key: YOUR_API_KEY" https://api.example.com/zerion/v1/wallets/0x.../portfolio
#
#   # CoinGecko API
#   curl -H "X-API-Key: YOUR_API_KEY" https://api.example.com/coingecko/api/v3/ping
#
#   # Alchemy JSON-RPC API (路径中的/v2/会被自动注入API_KEY)
#   curl -H "X-API-Key: YOUR_API_KEY" -X POST https://api.example.com/alchemy/v2 \
#        -H "Content-Type: application/json" \
#        -d '{"jsonrpc":"2.0","method":"eth_blockNumber","params":[],"id":1}'
#
# 网关自动转换规则:
# - Zerion: X-API-Key -> Authorization: Basic {base64(api_key:)}
# - CoinGecko: X-API-Key -> x_cg_demo_api_key Header
# - Alchemy: /v2/ -> /v2/{api_key}/ (URL路径注入)
# ============================================

# Zerion API Configuration
ZERION_ENDPOINT=https://api.zerion.io

# CoinGecko API Configuration
COINGECKO_ENDPOINT=https://api.coingecko.com

# Alchemy API Configuration
ALCHEMY_ENDPOINT=https://eth-mainnet.g.alchemy.com

# GeoIP Configuration (可选)
GEOIP_ENABLED=false
GEOIP_MODE=blacklist
GEOIP_COUNTRIES=CN,RU,KP
GEOIP_ALLOW_UNKNOWN=true
# GEOIP_DATABASE=/usr/local/openresty/geoip/GeoLite2-Country.mmdb

# Circuit Breaker Configuration (熔断器配置)
CIRCUIT_BREAKER_ENABLED=false
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT=30
CIRCUIT_BREAKER_HALF_OPEN_REQUESTS=3

# Rate Limiter Configuration (限流器配置)
RATE_LIMITER_ENABLED=false
RATE_LIMIT_GLOBAL=10000
RATE_LIMIT_PROVIDERS={"zerion":100,"coingecko":500,"alchemy":200}
RATE_LIMIT_IP=100
RATE_LIMIT_IP_BURST=20
RATE_LIMIT_API_KEY=1000
RATE_LIMIT_API_KEY_BURST=100
RATE_LIMIT_URI=50
RATE_LIMIT_URI_BURST=10

# Grafana Configuration
GRAFANA_PASSWORD=admin
